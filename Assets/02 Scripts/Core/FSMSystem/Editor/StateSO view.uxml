<ui:UXML xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:ui="UnityEngine.UIElements" xmlns:uie="UnityEditor.UIElements" noNamespaceSchemaLocation="../../../../../UIElementsSchema/UIElements.xsd" editor-extension-mode="True">
    <ui:VisualElement name="Container">
        <ui:TextField label="State name" placeholder-text="상태이름 입력(대문자로)" name="StateNameField" binding-path="stateName"/>
        <ui:DropdownField label="Class name" name="ClassNameDropdown" binding-path="className"/>
        <ui:IntegerField label="Asset index" name="AssetIndexField" binding-path="assetIndex"/>
        <uie:ObjectField label="Anim param" name="StateParamField" binding-path="stateParam" type="GGMLib.AnimatorSystem.AnimParamSO, Assembly-CSharp"/>
    </ui:VisualElement>
</ui:UXML>
